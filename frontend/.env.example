# ================================================================
# 돈킴이 프론트엔드 환경변수 설정 가이드
# 이 파일을 복사해 .env.development 또는 .env.production 으로 사용
# ================================================================

# Mock 모드
# true  → 가짜 데이터로 개발 (백엔드 없이 UI 작업 가능)
# false → 실제 백엔드 API 호출
VITE_USE_MOCK=true

# 백엔드 API 서버 주소
# - 개발(MOCK=true) : 값 상관없음 (API 호출 안 함)
# - 개발(MOCK=false): http://localhost:8080 → Vite proxy가 CORS 자동 처리
# - 프로덕션       : 실제 배포 URL 입력 (예: https://api.donkimi.com)
VITE_API_BASE_URL=http://localhost:8080
